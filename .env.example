# Google APIs Configuration
# ========================
# Google Search Console property URL (must match exactly in GSC)
GSC_PROPERTY=https://www.cim.org/

# Google Analytics 4 property ID (numeric ID from GA4 admin)
GA4_PROPERTY_ID=341629008

# PageSpeed Insights API key (get from Google Cloud Console)
PAGESPEED_API_KEY=your_pagespeed_api_key_here


# Monday.com Integration
# ======================
# Monday.com API token (get from your Monday.com profile)
MONDAY_API_TOKEN=your_monday_api_token_here

# Monday.com board item IDs for each report type
MONDAY_MASTER_ITEM_ID=your_master_item_id
MONDAY_GSC_ITEM_ID=your_gsc_item_id
MONDAY_GSC_KEYWORD_ITEM_ID=your_keyword_item_id
MONDAY_GSC_LANDING_ITEM_ID=your_landing_item_id
MONDAY_BROKEN_LINK_ITEM_ID=your_broken_link_item_id
MONDAY_INTERNAL_LINK_ITEM_ID=your_internal_link_item_id
MONDAY_CONTENT_AUDIT_ITEM_ID=your_content_audit_item_id
MONDAY_AI_SNIPPET_ITEM_ID=your_ai_snippet_item_id


# AI/LLM Configuration
# ====================
# Groq API key for AI-powered insights (get from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use for analysis
GROQ_MODEL=llama-3.3-70b-versatile


# Google Sheets Database
# ======================
# Google Sheet ID for historical data storage (from sheet URL)
GOOGLE_SHEET_ID=your_google_sheet_id_here


# Optional: Override specific report item IDs
# ===========================================
# These can be set to post specific reports to different Monday.com items
# If not set, the script will use the default MONDAY_ITEM_ID

# Example for overriding GA4 report destination:
# MONDAY_ITEM_ID=11818936551
